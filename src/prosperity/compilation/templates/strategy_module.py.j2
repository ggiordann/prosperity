                continue
            if kind == "constant":
                fair += weight * float(params["value"])
            elif kind == "mid":
                fair += weight * mid
            elif kind == "microprice":
                fair += weight * micro
            elif kind == "wall_mid":
                fair += weight * wall_mid
            elif kind == "ema":
                alpha = float(params.get("alpha", 0.2))
                key = f"{kind}_value"
                previous = float(product_state.get(key, mid))
                current = alpha * mid + (1.0 - alpha) * previous
                product_state[key] = current
                fair += weight * current

        signal_value = 0.0
        for signal in SPEC["signal_models"]:
            kind = signal["kind"]
            weight = signal.get("weight", 1.0)
            params = signal.get("params", {})
            target_product = params.get("product")
            if target_product and target_product != product:
                continue
            if kind == "mean_reversion":
                signal_value += weight * (fair - mid)
            elif kind == "momentum":
                last_mid = float(product_state.get("last_mid", mid))
                signal_value += weight * (mid - last_mid)
            elif kind == "imbalance":
                signal_value += weight * imbalance
            elif kind == "trade_pressure":
                signal_value += weight * float(product_state.get("trade_pressure", 0.0))
            elif kind == "volatility":
                last_mid = float(product_state.get("last_mid", mid))
                signal_value += weight * abs(mid - last_mid)

        product_state["last_mid"] = mid
        reservation = fair + signal_value
        risk = SPEC["risk_policy"]
