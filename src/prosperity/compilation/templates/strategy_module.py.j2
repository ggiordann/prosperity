class Trader:
    def bid(self):
        return 15

    def run(self, state: TradingState):
        persisted = self._load_state(state.traderData)
        result: Dict[str, List[Order]] = {}
        if FAMILY == "tutorial_submission_candidate_alpha":
            tomato_history = persisted.get("tomato_fair_history", [])
            for product in SPEC["scope"]["products"]:
                order_depth = state.order_depths.get(product)
                if order_depth is None or not order_depth.buy_orders or not order_depth.sell_orders:
                    result[product] = []
                    continue
                position = state.position.get(product, 0)
                if product == "EMERALDS":
                    result[product] = self._trade_submission_candidate_emeralds(order_depth, position)
                elif product == "TOMATOES":
                    orders, tomato_history = self._trade_submission_candidate_tomatoes(order_depth, position, tomato_history)
                    result[product] = orders
                else:
                    result[product] = []
            persisted["tomato_fair_history"] = tomato_history[-20:]
            return result, 0, json.dumps(persisted, separators=(",", ":"))

        for product in SPEC["scope"]["products"]:
            order_depth = state.order_depths.get(product)
            if order_depth is None or not order_depth.buy_orders or not order_depth.sell_orders:
                result[product] = []
