    def _limit(self, product: str) -> int:
        return int(SPEC["risk_policy"]["per_product_position_caps"].get(product, 20))

    def _param(self, name: str, default: float) -> float:
        return float(PARAMS.get(name, default))

    def _fair_component_weight(self, component: dict) -> float:
        params = component.get("params", {})
        label = params.get("label")
        weight = float(component.get("weight", 1.0))
        if label:
            return self._param(f"{label}_weight", weight)
        return weight

    def _signal_component_weight(self, signal: dict) -> float:
        base = float(signal.get("weight", 1.0))
        return self._param(f"{signal['name']}_weight", base)

    @staticmethod
    def _level_imbalance(order_depth: OrderDepth, level: int, best_bid_volume: int, best_ask_volume: int) -> float:
        bid_levels = sorted(order_depth.buy_orders, reverse=True)
        ask_levels = sorted(order_depth.sell_orders)
        if level <= 1:
            bid_volume = best_bid_volume
            ask_volume = best_ask_volume
        else:
            bid_price = bid_levels[level - 1] if len(bid_levels) >= level else bid_levels[-1]
            ask_price = ask_levels[level - 1] if len(ask_levels) >= level else ask_levels[-1]
            bid_volume = order_depth.buy_orders.get(bid_price, best_bid_volume)
            ask_volume = abs(order_depth.sell_orders.get(ask_price, -best_ask_volume))
        total = bid_volume + ask_volume
        return (bid_volume - ask_volume) / total if total else 0.0

    def _trade_submission_candidate_emeralds(self, order_depth: OrderDepth, position: int) -> List[Order]:
        best_bid = max(order_depth.buy_orders)
        best_ask = min(order_depth.sell_orders)
        spread = best_ask - best_bid
        bid_price = best_bid + 1 if spread > 1 else best_bid
        ask_price = best_ask - 1 if spread > 1 else best_ask
        quote_size = max(1, int(round(self._param("emeralds_quote_size", 5.0))))
        limit = self._limit("EMERALDS")
        buy_size = min(quote_size, max(0, limit - position))
        sell_size = min(quote_size, max(0, limit + position))
        orders: List[Order] = []
        if buy_size > 0 and bid_price < best_ask:
            orders.append(Order("EMERALDS", bid_price, buy_size))
        if sell_size > 0 and ask_price > best_bid:
            orders.append(Order("EMERALDS", ask_price, -sell_size))
        return orders

    def _trade_submission_candidate_tomatoes(
        self,
        order_depth: OrderDepth,
        position: int,
        history: List[float],
    ) -> Tuple[List[Order], List[float]]:
        best_bid = max(order_depth.buy_orders)
        best_ask = min(order_depth.sell_orders)
        limit = self._limit("TOMATOES")

        filter_volume = max(1, int(round(self._param("tomato_filter_volume", 16.0))))
        filtered_asks = [price for price, volume in order_depth.sell_orders.items() if abs(volume) >= filter_volume]
        filtered_bids = [price for price, volume in order_depth.buy_orders.items() if abs(volume) >= filter_volume]
        mm_ask = min(filtered_asks) if filtered_asks else best_ask
        mm_bid = max(filtered_bids) if filtered_bids else best_bid
        fair_value = 0.5 * (mm_ask + mm_bid)

        bid_volume_1 = order_depth.buy_orders[best_bid]
        ask_volume_1 = abs(order_depth.sell_orders[best_ask])
        total_volume = bid_volume_1 + ask_volume_1
        microprice = (best_ask * bid_volume_1 + best_bid * ask_volume_1) / total_volume if total_volume else fair_value

        history.append(fair_value)
        prev1 = history[-2] if len(history) >= 2 else fair_value
        prev3 = history[-4] if len(history) >= 4 else prev1
        if len(history) >= 4:
            fair_value = 0.6 * fair_value + 0.25 * history[-2] + 0.15 * history[-4]
        elif len(history) >= 2:
            fair_value = 0.75 * fair_value + 0.25 * history[-2]

        second_bids = sorted(order_depth.buy_orders, reverse=True)
        second_asks = sorted(order_depth.sell_orders)
        bid2 = second_bids[1] if len(second_bids) > 1 else best_bid
        ask2 = second_asks[1] if len(second_asks) > 1 else best_ask
        bid2_vol = order_depth.buy_orders.get(bid2, bid_volume_1)
        ask2_vol = abs(order_depth.sell_orders.get(ask2, ask_volume_1))
        second_total = bid2_vol + ask2_vol
        second_imb = (bid2_vol - ask2_vol) / second_total if second_total else 0.0
        gap_signal = (ask2 - best_ask) - (best_bid - bid2)
        ret1 = fair_value - prev1
        ret3 = fair_value - prev3
        micro_delta = microprice - fair_value

        alpha = self._param("fair_alpha_scale", 1.3) * (
            self._param("gap_weight", 0.1) * gap_signal
            + self._param("second_imb_weight", 1.0) * second_imb
            + self._param("ret1_weight", -0.045) * ret1
            + self._param("ret3_weight", 0.0) * ret3
            + self._param("micro_weight", -0.025) * micro_delta
        )
        fair_value = fair_value + alpha - self._param("inventory_skew", 0.0) * (position / max(1, limit))

        orders: List[Order] = []
        buy_volume = 0
        sell_volume = 0
        take_width = max(0, int(round(self._param("tomato_take_width", 2.0))))
        take_extra = self._param("take_extra", 1.5)
        buy_take_width = max(0, take_width - int(abs(alpha) >= take_extra and alpha > 0))
        sell_take_width = max(0, take_width - int(abs(alpha) >= take_extra and alpha < 0))

        best_ask_size = -order_depth.sell_orders[best_ask]
        if best_ask <= fair_value - buy_take_width:
            quantity = min(best_ask_size, limit - position - buy_volume)
            if quantity > 0:
                orders.append(Order("TOMATOES", best_ask, quantity))
                buy_volume += quantity

        best_bid_size = order_depth.buy_orders[best_bid]
        if best_bid >= fair_value + sell_take_width:
            quantity = min(best_bid_size, limit + position - sell_volume)
            if quantity > 0:
                orders.append(Order("TOMATOES", best_bid, -quantity))
                sell_volume += quantity

        position_after_take = position + buy_volume - sell_volume
        clear_width = self._param("clear_width", 1.0)
        fair_bid = round(fair_value - clear_width)
        fair_ask = round(fair_value + clear_width)
        if position_after_take > 0 and fair_ask in order_depth.buy_orders:
            quantity = min(order_depth.buy_orders[fair_ask], position_after_take, limit + position - sell_volume)
            if quantity > 0:
                orders.append(Order("TOMATOES", fair_ask, -quantity))
                sell_volume += quantity
        if position_after_take < 0 and fair_bid in order_depth.sell_orders:
            quantity = min(abs(order_depth.sell_orders[fair_bid]), -position_after_take, limit - position - buy_volume)
            if quantity > 0:
                orders.append(Order("TOMATOES", fair_bid, quantity))
                buy_volume += quantity

        quote_aggression = int(round(self._param("quote_aggression", 1.0)))
        shift = quote_aggression if alpha > take_extra else (-quote_aggression if alpha < -take_extra else 0)
        ask_candidates = [price for price in order_depth.sell_orders if price > fair_value + 1]
        bid_candidates = [price for price in order_depth.buy_orders if price < fair_value - 1]
        ask_price = min(ask_candidates) - 1 - max(0, -shift) if ask_candidates else int(round(fair_value + 2 - max(0, -shift)))
        bid_price = max(bid_candidates) + 1 + max(0, shift) if bid_candidates else int(round(fair_value - 2 + max(0, shift)))
        bid_price = min(bid_price, best_ask - 1)
        ask_price = max(ask_price, best_bid + 1)

        buy_size = limit - (position + buy_volume)
        sell_size = limit + (position - sell_volume)
        if buy_size > 0:
            orders.append(Order("TOMATOES", bid_price, buy_size))
        if sell_size > 0:
            orders.append(Order("TOMATOES", ask_price, -sell_size))
        return orders, history

    def _trade_product(self, product: str, order_depth: OrderDepth, position: int, product_state: dict) -> List[Order]:
        best_bid = max(order_depth.buy_orders)
        best_ask = min(order_depth.sell_orders)
        best_bid_volume = order_depth.buy_orders[best_bid]
        best_ask_volume = abs(order_depth.sell_orders[best_ask])
        spread = best_ask - best_bid
        mid = 0.5 * (best_bid + best_ask)
        total = best_bid_volume + best_ask_volume
        micro = (best_ask * best_bid_volume + best_bid * best_ask_volume) / total if total else mid
        imbalance = (best_bid_volume - best_ask_volume) / total if total else 0.0

        bid_levels = sorted(order_depth.buy_orders, reverse=True)
        ask_levels = sorted(order_depth.sell_orders)
        bid2 = bid_levels[1] if len(bid_levels) > 1 else best_bid
        ask2 = ask_levels[1] if len(ask_levels) > 1 else best_ask
        bid2_volume = order_depth.buy_orders.get(bid2, best_bid_volume)
        ask2_volume = abs(order_depth.sell_orders.get(ask2, -best_ask_volume))
        gap_signal = (ask2 - best_ask) - (best_bid - bid2)

        mid_history = list(product_state.get("mid_history", []))
        mid_history.append(mid)
        product_state["mid_history"] = mid_history[-16:]
        spread_history = list(product_state.get("spread_history", []))
        spread_history.append(spread)
        product_state["spread_history"] = spread_history[-16:]

        fair = 0.0
        for component in SPEC["fair_value_models"]:
            kind = component["kind"]
            weight = self._fair_component_weight(component)
            params = component.get("params", {})
            target_product = params.get("product")
            if target_product and target_product != product:
                continue
            if kind == "constant":
                fair += weight * float(params["value"])
            elif kind == "mid":
                fair += weight * mid
            elif kind == "microprice":
                fair += weight * micro
            elif kind == "wall_mid":
                threshold_key = params.get("threshold_param")
                threshold_default = float(params.get("threshold", 15))
                threshold = int(round(self._param(str(threshold_key), threshold_default))) if threshold_key else int(round(threshold_default))
                wall_bid = max((price for price, volume in order_depth.buy_orders.items() if volume >= threshold), default=best_bid)
                wall_ask = min((price for price, volume in order_depth.sell_orders.items() if abs(volume) >= threshold), default=best_ask)
                fair += weight * (0.5 * (wall_bid + wall_ask))
            elif kind == "ema":
                alpha_key = params.get("alpha_param")
                alpha_default = float(params.get("alpha", 0.2))
                alpha = self._param(str(alpha_key), alpha_default) if alpha_key else alpha_default
                source = params.get("source", "mid")
                if source == "microprice":
                    source_value = micro
                elif source == "wall_mid":
                    threshold_default = float(params.get("threshold", 15))
                    threshold = int(round(self._param(str(params.get("threshold_param")), threshold_default))) if params.get("threshold_param") else int(round(threshold_default))
                    wall_bid = max((price for price, volume in order_depth.buy_orders.items() if volume >= threshold), default=best_bid)
                    wall_ask = min((price for price, volume in order_depth.sell_orders.items() if abs(volume) >= threshold), default=best_ask)
                    source_value = 0.5 * (wall_bid + wall_ask)
                else:
                    source_value = mid
                key = f"{kind}_{source}_value"
                previous = float(product_state.get(key, source_value))
                current = alpha * source_value + (1.0 - alpha) * previous
                product_state[key] = current
                fair += weight * current

        signal_value = 0.0
        for signal in SPEC["signal_models"]:
            kind = signal["kind"]
            weight = self._signal_component_weight(signal)
            params = signal.get("params", {})
            target_product = params.get("product")
            if target_product and target_product != product:
                continue
            if kind == "mean_reversion":
                signal_value += weight * (fair - mid)
            elif kind == "momentum":
                lag = max(1, int(params.get("lag", 1)))
                previous = mid_history[-(lag + 1)] if len(mid_history) > lag else mid
                signal_value += weight * (mid - previous)
            elif kind == "imbalance":
                signal_value += weight * imbalance
            elif kind == "trade_pressure":
                previous = mid_history[-2] if len(mid_history) >= 2 else mid
                signal_value += weight * imbalance * (mid - previous)
            elif kind == "volatility":
                previous = mid_history[-2] if len(mid_history) >= 2 else mid
                signal_value += weight * abs(mid - previous)
            elif kind == "gap_asymmetry":
                signal_value += weight * gap_signal
            elif kind == "level_imbalance":
                signal_value += weight * self._level_imbalance(order_depth, int(params.get("level", 2)), best_bid_volume, best_ask_volume)
            elif kind == "lagged_return":
                lag = max(1, int(params.get("lag", 1)))
                previous = mid_history[-(lag + 1)] if len(mid_history) > lag else mid
                signal_value += weight * (mid - previous)
            elif kind == "micro_delta":
                signal_value += weight * (micro - fair)
            elif kind == "spread_compression":
                previous_spreads = spread_history[:-1]
                rolling_spread = sum(previous_spreads) / len(previous_spreads) if previous_spreads else spread
                signal_value += weight * (rolling_spread - spread)

        product_state["last_mid"] = mid
        signal_scale = self._param("signal_scale", 1.0)
        reservation = fair + signal_scale * signal_value + self._param("reservation_bias", 0.0)
        risk = SPEC["risk_policy"]
        limit = int(risk["per_product_position_caps"].get(product, 20))
        max_aggressive = int(risk.get("max_aggressive_size", 10))
        mm = SPEC["execution_policy"]["market_making"]
        inventory_skew = self._param("inventory_skew", float(mm.get("inventory_skew", 0.0)))
        reservation -= inventory_skew * (position / max(1, limit)) * max(1.0, spread)

        orders: List[Order] = []
        taking = SPEC["execution_policy"]["taking"]
        if taking.get("enabled", True):
            min_edge = self._param("taking_min_edge", float(taking.get("min_edge", 1.0)))
            max_size = max(1, int(round(self._param("taking_max_size", float(taking.get("max_size", max_aggressive))))))
            taking_style = taking.get("params", {}).get("style", "balanced")
            if taking_style == "strict":
                min_edge += 0.5
            elif taking_style == "aggressive":
                min_edge = max(0.0, min_edge - 0.5)

            buy_allowed = best_ask <= reservation - min_edge
            sell_allowed = best_bid >= reservation + min_edge
            if taking_style == "breakout":
                buy_allowed = buy_allowed and signal_value > 0
                sell_allowed = sell_allowed and signal_value < 0
            elif taking_style == "reversion":
                buy_allowed = buy_allowed and (micro <= fair or gap_signal < 0)
                sell_allowed = sell_allowed and (micro >= fair or gap_signal > 0)

            if buy_allowed:
                buy_size = min(best_ask_volume, max_size, limit - position)
                if buy_size > 0:
                    orders.append(Order(product, best_ask, buy_size))
            if sell_allowed:
                sell_size = min(best_bid_volume, max_size, limit + position)
                if sell_size > 0:
                    orders.append(Order(product, best_bid, -sell_size))

        current_position = position + sum(order.quantity for order in orders)
        clear_width = self._param("clear_width", float(SPEC["execution_policy"].get("clear_inventory_width", 0.0)))
        fair_level_bid = int(reservation - clear_width)
        fair_level_ask = int(reservation + clear_width)
        if current_position > 0 and fair_level_ask in order_depth.buy_orders:
            quantity = min(order_depth.buy_orders[fair_level_ask], current_position, limit + position)
            if quantity > 0:
                orders.append(Order(product, fair_level_ask, -quantity))
        elif current_position < 0 and fair_level_bid in order_depth.sell_orders:
            quantity = min(abs(order_depth.sell_orders[fair_level_bid]), -current_position, limit - position)
            if quantity > 0:
                orders.append(Order(product, fair_level_bid, quantity))

        if mm.get("enabled", True):
            buy_remaining = max(0, limit - position - sum(max(0, order.quantity) for order in orders))
            sell_remaining = max(0, limit + position - sum(max(0, -order.quantity) for order in orders))
            quote_style = mm.get("params", {}).get("style", "balanced")
            layer_offset_scale = self._param("layer_offset_scale", 1.0)
            layer_size_scale = self._param("layer_size_scale", 1.0)
            quote_reservation = reservation
            if quote_style == "signal_skew":
                quote_reservation += 0.25 * signal_value
            elif quote_style == "inventory_first":
                quote_reservation -= 0.5 * (position / max(1, limit)) * max(1.0, spread)
            elif quote_style == "passive_wide":
                layer_offset_scale *= 1.25

            for layer in mm.get("layers", []):
                target_product = layer.get("product")
                if target_product and target_product != product:
                    continue
                offset = float(layer.get("offset", mm.get("base_half_spread", 2.0))) * layer_offset_scale
                size = max(1, int(round(float(layer.get("size", 5)) * layer_size_scale)))
                side = layer["side"]
                if quote_style == "one_sided":
                    if signal_value > 0 and side == "sell":
                        size = max(1, int(round(size * 0.55)))
                    elif signal_value < 0 and side == "buy":
                        size = max(1, int(round(size * 0.55)))
                if side == "buy" and buy_remaining > 0:
                    model_price = int(round(quote_reservation - offset))
                    if layer.get("join_best", True):
                        price = min(best_ask - 1, max(best_bid + 1, model_price))
                    else:
                        price = min(best_ask - 1, model_price)
                    quantity = min(size, buy_remaining)
                    if quantity > 0 and price < best_ask:
                        orders.append(Order(product, price, quantity))
                        buy_remaining -= quantity
                elif side == "sell" and sell_remaining > 0:
                    model_price = int(round(quote_reservation + offset))
                    if layer.get("join_best", True):
                        price = max(best_bid + 1, min(best_ask - 1, model_price))
                    else:
                        price = max(best_bid + 1, model_price)
                    quantity = min(size, sell_remaining)
                    if quantity > 0 and price > best_bid:
                        orders.append(Order(product, price, -quantity))
                        sell_remaining -= quantity
        return orders

    @staticmethod
    def _load_state(trader_data: str):
        if not trader_data:
            return {}
        try:
            payload = json.loads(trader_data)
        except json.JSONDecodeError:
            return {}
        return payload if isinstance(payload, dict) else {}
